pipeline {
    agent any

    stages {
        stage('Step 1: Environment Check') {
            steps {
                echo 'Verifying Docker Access...'
                // Verify we can talk to the host's Docker engine
                sh 'docker version'
            }
        }

        stage('Step 2: Rebuild App Only') {
            steps {
                echo 'Building and updating only the App container...'
                // --build forces a fresh image build
                // --no-deps ensures we don't restart mongo or jenkins
                sh 'docker compose up -d --build --no-deps app'
            }
        }

        stage('Step 3: Verification') {
            steps {
                echo 'Checking if App is running...'
                sh 'docker ps | grep dockercleanerpro-app'
            }
        }
    }

    post {
        success {
            echo 'Deployment successful!'
        }
        failure {
            echo 'Deployment failed. Check the Jenkins logs.'
        }
    }
}